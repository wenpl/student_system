/* pages/profile/notification-settings/index.wxss - 现代简约通知设置页面 */

.page-container {
  min-height: 100vh;
  background-color: var(--bg-page);
}

/* ==================== 表单区块 ==================== */
.form-section {
  margin: 24rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.form-value {
  font-size: 30rpx;
  color: var(--text-secondary);
}

/* ==================== 提示 ==================== */
.tip-section {
  padding: 0 48rpx;
}

.tip-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1.6;
}
