/* pages/profile/edit/index.wxss - 现代简约编辑资料页面 */

.edit-container {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding-bottom: 120rpx;
}

/* ==================== 表单区块 ==================== */
.form-section {
  margin: 24rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: var(--text-primary);
  width: 160rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: var(--text-primary);
}

.form-value {
  font-size: 30rpx;
  color: var(--text-tertiary);
}

/* ==================== 头像 ==================== */
.avatar-item {
  padding: 20rpx 24rpx;
}

.avatar-right {
  display: flex;
  align-items: center;
}

.avatar-preview {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.2);
}

.form-arrow {
  font-size: 28rpx;
  color: var(--text-tertiary);
  margin-left: 16rpx;
}

/* ==================== 性别单选 ==================== */
.radio-group {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: flex-end;
}

.radio-label {
  display: flex;
  align-items: center;
  margin-left: 32rpx;
  font-size: 30rpx;
  color: var(--text-primary);
}

.radio-label text {
  margin-left: 8rpx;
}

/* ==================== 日期选择器 ==================== */
.picker-value {
  font-size: 30rpx;
  color: var(--text-primary);
  text-align: right;
  font-weight: 500;
}

.picker-value.placeholder {
  color: var(--text-placeholder);
}

/* ==================== 个人简介 ==================== */
.bio-item {
  flex-direction: column;
  align-items: flex-start;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  margin-top: 16rpx;
  padding: 16rpx 0;
  line-height: 1.6;
}

/* ==================== 账号密码只读提示 ==================== */
.readonly-tip {
  font-size: 26rpx;
  color: var(--warning-color);
  font-weight: 500;
}

/* ==================== 保存按钮 ==================== */
.btn-section {
  padding: 48rpx 24rpx;
}

.btn-save {
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  height: 96rpx;
  font-size: 35rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 217, 0.3);
  transition: all 0.25s ease;
  letter-spacing: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-save:active {
  transform: scale(0.98);
}

.btn-save::after {
  border: none;
}
