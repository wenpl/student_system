/* pages/profile/about/index.wxss - 现代简约关于页面 */

.page-container {
  min-height: 100vh;
  background-color: var(--bg-page);
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ==================== Logo区域 ==================== */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
}

.logo-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.3);
}

.logo-text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.app-name {
  font-size: 36rpx;
  color: var(--text-primary);
  font-weight: 700;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.app-version {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ==================== 信息区块 ==================== */
.info-section {
  width: calc(100% - 48rpx);
  margin: 40rpx 24rpx 0;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-sizing: border-box;
  padding: 0 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.info-value {
  font-size: 30rpx;
  color: var(--text-secondary);
}

/* ==================== 底部 ==================== */
.footer {
  position: fixed;
  bottom: 60rpx;
  text-align: center;
}

.copyright {
  font-size: 24rpx;
  color: var(--text-placeholder);
}
