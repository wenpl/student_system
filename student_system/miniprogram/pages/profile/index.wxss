/* pages/profile/index.wxss - 现代简约个人中心页面 */

.profile-container {
  min-height: 100vh;
  background-color: var(--bg-page);
}

/* ==================== 用户信息 ==================== */
.user-section {
  display: flex;
  align-items: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(165deg, #4A90D9 0%, #36B5A0 100%);
  position: relative;
  overflow: hidden;
}

.user-section::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  background-color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.user-info {
  margin-left: 24rpx;
  position: relative;
  z-index: 1;
}

.nick-name {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.role-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ==================== 角色切换 ==================== */
.switch-section {
  margin: 24rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.role-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.role-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
}

.role-item:active {
  transform: scale(0.99);
}

.role-item.active {
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.1) 0%, rgba(54, 181, 160, 0.05) 100%);
  border-color: var(--primary-color);
}

.role-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.role-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* ==================== 菜单 ==================== */
.menu-section {
  padding: 0 24rpx;
}

.menu-group {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: rgba(0, 0, 0, 0.02);
}

.menu-text {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.logout-text {
  color: var(--error-color);
}

.menu-arrow {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* ==================== 版本信息 ==================== */
.version-info {
  text-align: center;
  padding: 48rpx 0;
  padding-bottom: 140rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ==================== 底部导航 ==================== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #FFFFFF;
  display: flex;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.nav-item.active .nav-text {
  color: var(--primary-color);
  font-weight: 600;
}

.nav-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}
