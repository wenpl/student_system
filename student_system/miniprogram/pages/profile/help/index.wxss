/* pages/profile/help/index.wxss - 现代简约帮助中心页面 */

.page-container {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding-bottom: 40rpx;
}

/* ==================== 区块标题 ==================== */
.section-title {
  padding: 24rpx 32rpx 16rpx;
  font-size: 28rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

/* ==================== FAQ列表 ==================== */
.faq-list {
  margin: 0 24rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.faq-item {
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  transition: background-color 0.2s ease;
}

.faq-question:active {
  background-color: rgba(0, 0, 0, 0.02);
}

.question-text {
  font-size: 30rpx;
  color: var(--text-primary);
  flex: 1;
  font-weight: 500;
}

.arrow {
  font-size: 28rpx;
  color: var(--text-tertiary);
  transition: transform 0.3s;
  transform: rotate(90deg);
}

.arrow-up {
  transform: rotate(-90deg);
}

.faq-answer {
  padding: 0 24rpx 28rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* ==================== 联系方式 ==================== */
.contact-section {
  margin-top: 24rpx;
}

.contact-info {
  margin: 0 24rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  line-height: 1.8;
}

.contact-info .highlight {
  color: var(--primary-color);
  font-weight: 500;
}
