/* pages/profile/change-password/index.wxss - 现代简约修改密码页面 */

.page-container {
  min-height: 100vh;
  background-color: var(--bg-page);
}

/* ==================== 表单区块 ==================== */
.form-section {
  margin: 24rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: var(--text-primary);
  width: 160rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: var(--text-primary);
}

/* ==================== 提示 ==================== */
.tip-section {
  padding: 0 48rpx;
  margin-bottom: 48rpx;
}

.tip-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1.6;
}

/* ==================== 保存按钮 ==================== */
.btn-section {
  padding: 0 24rpx;
}

.btn-save {
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  height: 96rpx;
  font-size: 35rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 217, 0.3);
  transition: all 0.25s ease;
  letter-spacing: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-save:active {
  transform: scale(0.98);
}

.btn-save::after {
  border: none;
}
