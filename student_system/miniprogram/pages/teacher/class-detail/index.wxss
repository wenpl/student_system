/* pages/teacher/class-detail/index.wxss - 现代简约班级详情页面 */

.class-detail-container {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* ==================== 班级卡片 ==================== */
.class-card {
  background: linear-gradient(165deg, #4A90D9 0%, #36B5A0 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.3);
}

.class-card::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.class-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.class-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.class-info {
  display: flex;
  flex-direction: column;
}

.class-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 4rpx;
  letter-spacing: 1rpx;
}

.class-meta {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.class-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background-color: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  border-radius: 16rpx;
  padding: 20rpx 0;
  position: relative;
  z-index: 1;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(255,255,255,0.3) 50%, transparent 100%);
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ==================== 标签栏 ==================== */
.tab-bar {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: 16rpx;
  transition: all 0.25s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.3);
}

/* ==================== 通用区块 ==================== */
.section {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* ==================== 学员列表 ==================== */
.student-list {
  margin-bottom: 24rpx;
}

.student-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
  transition: background-color 0.2s ease;
}

.student-item:last-child {
  border-bottom: none;
}

.student-item:active {
  background-color: rgba(0, 0, 0, 0.02);
  margin: 0 -28rpx;
  padding: 20rpx 28rpx;
}

.student-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.2);
}

.student-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.student-name {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 4rpx;
}

.student-meta {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.student-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.student-status.normal {
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.1) 0%, rgba(82, 196, 26, 0.05) 100%);
  color: var(--success-color);
}

.student-status.warning {
  background: linear-gradient(135deg, rgba(250, 173, 20, 0.1) 0%, rgba(250, 173, 20, 0.05) 100%);
  color: var(--warning-color);
}

.student-status.error {
  background: linear-gradient(135deg, rgba(255, 77, 79, 0.1) 0%, rgba(255, 77, 79, 0.05) 100%);
  color: var(--error-color);
}

/* ==================== 课程安排 ==================== */
.schedule-list {
  margin-bottom: 16rpx;
}

.schedule-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.schedule-item:last-child {
  border-bottom: none;
}

.schedule-item.today {
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.08) 0%, rgba(54, 181, 160, 0.04) 100%);
  margin: 0 -28rpx;
  padding: 20rpx 28rpx;
  border-radius: 16rpx;
}

.schedule-item.past {
  opacity: 0.6;
}

.schedule-date {
  width: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
}

.date-day {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.date-week {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.schedule-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.schedule-time {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 4rpx;
  font-weight: 500;
}

.schedule-class {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.today-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  border-radius: 12rpx;
  font-weight: 500;
}

/* ==================== 快捷操作 ==================== */
.action-bar {
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.action-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  transition: all 0.25s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.primary {
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

.action-btn:active {
  transform: scale(0.98);
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.1) 0%, rgba(54, 181, 160, 0.05) 100%);
  border-radius: 50%;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}
