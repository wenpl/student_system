/* pages/teacher/index.wxss - 现代简约老师端首页 */

.teacher-container {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding-bottom: 120rpx;
}

/* ==================== 未读小红点 ==================== */
.unread-dot {
  position: absolute;
  top: 0;
  right: 20rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF4D4F 0%, #FF7875 100%);
}

/* ==================== 顶部信息 ==================== */
.header-section {
  background: linear-gradient(165deg, #4A90D9 0%, #36B5A0 100%);
  padding: 48rpx 32rpx 80rpx;
  position: relative;
  overflow: hidden;
}

.header-section::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.user-info {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.user-text {
  margin-left: 24rpx;
}

.greeting {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.sub-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 1rpx;
}

/* ==================== 区块 ==================== */
.section {
  margin: 24rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.section-more {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
}

/* ==================== 快捷功能 ==================== */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 8rpx 0;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.action-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  font-size: 40rpx;
  transition: transform 0.2s ease;
}

.action-icon image {
  width: 44rpx;
  height: 44rpx;
}

.action-icon.booking {
  background: linear-gradient(135deg, #E0F2FE 0%, #BAE6FD 100%);
}

.action-icon.notice {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.action-icon.comment {
  background: linear-gradient(135deg, #DCFCE7 0%, #BBF7D0 100%);
}

.action-item:active .action-icon {
  transform: scale(0.95);
}

.action-name {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #FF4D4F 0%, #FF7875 100%);
  color: #FFFFFF;
  font-size: 20rpx;
  text-align: center;
  padding: 0 8rpx;
}

/* ==================== 班级列表 ==================== */
.class-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.class-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  transition: all 0.25s ease;
  border: 1rpx solid rgba(74, 144, 217, 0.08);
}

.class-card:active {
  transform: scale(0.99);
}

.class-info {
  flex: 1;
}

.class-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.class-type {
  font-size: 24rpx;
  color: var(--primary-color);
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.1) 0%, rgba(54, 181, 160, 0.05) 100%);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.class-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-right: 16rpx;
}

.student-count, .class-time {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.4;
}

/* ==================== 课程卡片 ==================== */
.course-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.course-card {
  padding: 24rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(74, 144, 217, 0.08);
}

.course-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.course-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.course-time {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
}

.course-body {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.class-name, .location {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.course-footer {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

/* ==================== 待办事项 ==================== */
.todo-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.todo-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  transition: all 0.25s ease;
}

.todo-item:active {
  transform: scale(0.99);
}

.todo-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #FFFFFF;
  margin-right: 16rpx;
  font-weight: 600;
}

.todo-icon.booking {
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
}

.todo-icon.trial {
  background: linear-gradient(135deg, #FAAD14 0%, #FFC53D 100%);
}

.todo-content {
  flex: 1;
}

.todo-title {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 4rpx;
}

.todo-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.action-tag {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.action-tag.trial {
  background: linear-gradient(135deg, rgba(250, 173, 20, 0.1) 0%, rgba(250, 173, 20, 0.05) 100%);
  color: var(--warning-color);
}

/* ==================== 空状态 ==================== */
.empty-state {
  padding: 48rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* ==================== 底部导航 ==================== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #FFFFFF;
  display: flex;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.nav-item.active .nav-text {
  color: var(--primary-color);
  font-weight: 600;
}

.nav-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}
