/* pages/teacher/student-detail/index.wxss - 现代简约老师端学员详情 */

.student-detail {
  padding: 24rpx;
  background: var(--bg-page);
  min-height: 100vh;
  padding-bottom: 48rpx;
}

/* ==================== 学员信息卡片 ==================== */
.info-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  margin-bottom: 12rpx;
}

.name {
  display: inline;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.name-en {
  display: inline;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-left: 12rpx;
}

.card-meta {
  display: flex;
  align-items: center;
}

.meta-item {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.meta-divider {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin: 0 12rpx;
  opacity: 0.5;
}

/* ==================== 分区 ==================== */
.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

/* ==================== 信息列表 ==================== */
.info-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.info-value.highlight {
  color: var(--primary-color);
  font-weight: 600;
}

/* ==================== 编辑区域 ==================== */
.edit-item {
  margin-bottom: 24rpx;
}

.edit-item:last-child {
  margin-bottom: 0;
}

.edit-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.edit-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.edit-input {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
  box-sizing: border-box;
}

.edit-input:focus {
  background: #FFFFFF;
  border-color: var(--primary-color);
}

.edit-picker {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
}

.picker-text {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.btn-small {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 32rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  border-radius: 16rpx;
  white-space: nowrap;
  flex-shrink: 0;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.2);
}

/* ==================== 评语输入 ==================== */
.comment-textarea {
  width: 100%;
  height: 200rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
}

.comment-textarea:focus {
  background: #FFFFFF;
  border-color: var(--primary-color);
}

.comment-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.char-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.btn-submit {
  height: 72rpx;
  padding: 0 40rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  border-radius: 36rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.2);
  letter-spacing: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ==================== 评语列表 ==================== */
.empty-state {
  text-align: center;
  padding: 48rpx 0;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.comment-list {
}

.comment-item {
  padding: 20rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.comment-item:last-child {
  margin-bottom: 0;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.comment-teacher {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 600;
}

.comment-date {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.comment-content {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  display: block;
}
