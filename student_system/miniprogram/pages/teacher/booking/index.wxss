/* pages/teacher/booking/index.wxss - 现代简约老师约课页面 */

.teacher-booking-container {
  min-height: 100vh;
  background-color: var(--bg-page);
}

/* ==================== 日期选择 ==================== */
.date-section {
  background-color: #FFFFFF;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

/* ==================== 日期行 ==================== */
.date-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.date-btn {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 32rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  font-size: 28rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
  transition: all 0.25s ease;
}

.date-btn.active {
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.3);
}

.date-picker-wrap {
  flex: 1;
}

.date-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 24rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
}

.date-picker.active {
  border-color: var(--primary-color);
  background: #FFFFFF;
}

.date-value {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.date-arrow {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* ==================== 时间段区块 ==================== */
.section {
  margin: 16rpx 24rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* ==================== 时间段列表 ==================== */
.slot-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.slot-item:last-child {
  border-bottom: none;
}

.slot-time-col {
  width: 200rpx;
  flex-shrink: 0;
  display: flex;
  align-items: flex-start;
  padding-top: 4rpx;
}

.slot-time {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.slot-content-col {
  flex: 1;
}

.slot-item.has-booking {
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.04) 0%, rgba(54, 181, 160, 0.02) 100%);
  margin: 0 -28rpx;
  padding: 20rpx 28rpx;
  border-radius: 12rpx;
}

.booking-detail {
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.1) 0%, rgba(54, 181, 160, 0.05) 100%);
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  border-left: 4rpx solid var(--primary-color);
}

.booking-detail:last-child {
  margin-bottom: 0;
}

.detail-student {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 4rpx;
}

.detail-parent {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.free-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ==================== 加载状态 ==================== */
.loading-state {
  text-align: center;
  padding: 60rpx 0;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

/* ==================== 全部约课列表 ==================== */
.all-booking-list {
  display: flex;
  flex-direction: column;
}

.all-booking-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
  transition: background-color 0.2s ease;
}

.all-booking-item:last-child {
  border-bottom: none;
}

.all-booking-item:active {
  background-color: rgba(0, 0, 0, 0.02);
  margin: 0 -28rpx;
  padding: 20rpx 28rpx;
}

.all-booking-date {
  width: 200rpx;
  flex-shrink: 0;
}

.all-date-text {
  display: block;
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.all-time-text {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

.all-booking-info {
  flex: 1;
}

.all-student-name {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 4rpx;
}

.all-parent-name {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.all-booking-type {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.all-booking-type.trial {
  background: linear-gradient(135deg, rgba(250, 173, 20, 0.1) 0%, rgba(250, 173, 20, 0.05) 100%);
  color: var(--warning-color);
}
