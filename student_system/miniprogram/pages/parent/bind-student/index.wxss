/* pages/parent/bind-student/index.wxss - 现代简约绑定学员页面 */

.bind-container {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding: 24rpx;
  padding-bottom: 140rpx;
}

/* ==================== 表单区块 ==================== */
.form-section {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
  box-sizing: border-box;
}

.form-input:focus {
  background: #FFFFFF;
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(74, 144, 217, 0.1);
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  padding: 0 24rpx;
  transition: all 0.25s ease;
}

.form-picker:active {
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.06) 0%, rgba(54, 181, 160, 0.03) 100%);
}

.form-picker .placeholder {
  color: var(--text-tertiary);
}

.form-picker .selected {
  color: var(--text-primary);
  font-weight: 500;
}

.picker-arrow {
  color: var(--text-tertiary);
}

/* ==================== 关系选择 ==================== */
.relation-list {
  display: flex;
  gap: 16rpx;
}

.relation-item {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
}

.relation-item.active {
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.1) 0%, rgba(54, 181, 160, 0.05) 100%);
  color: var(--primary-color);
  border-color: var(--primary-color);
  font-weight: 600;
}

/* ==================== 提示文字 ==================== */
.tips {
  padding: 24rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
  line-height: 1.6;
}

/* ==================== 提交按钮 ==================== */
.btn-submit {
  position: fixed;
  bottom: 48rpx;
  left: 24rpx;
  right: 24rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 35rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 217, 0.3);
  transition: all 0.25s ease;
  letter-spacing: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-submit:active {
  transform: scale(0.98);
}

.btn-submit::after {
  border: none;
}
