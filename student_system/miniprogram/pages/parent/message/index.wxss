/* pages/parent/message/index.wxss - 现代简约消息页面 */

.message-container {
  min-height: 100vh;
  background-color: var(--bg-page);
}

/* ==================== 标签栏 ==================== */
.tab-bar {
  display: flex;
  background-color: #FFFFFF;
  padding: 16rpx 24rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: var(--text-secondary);
  position: relative;
  transition: all 0.25s ease;
}

.tab-item.active {
  color: var(--primary-color);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #4A90D9 0%, #36B5A0 100%);
  border-radius: 3rpx;
}

.badge {
  position: absolute;
  top: 8rpx;
  right: 24rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  background: linear-gradient(135deg, #FF4D4F 0%, #FF7875 100%);
  color: #FFFFFF;
  font-size: 20rpx;
  border-radius: 16rpx;
  padding: 0 8rpx;
  text-align: center;
}

/* ==================== 通知公告 ==================== */
.notice-section {
  padding: 24rpx;
}

.notice-list {
  margin-bottom: 24rpx;
}

.notice-item {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.25s ease;
}

.notice-item:active {
  transform: scale(0.99);
}

.notice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.notice-type {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.notice-type.important {
  background: linear-gradient(135deg, rgba(255, 77, 79, 0.1) 0%, rgba(255, 77, 79, 0.05) 100%);
  color: var(--error-color);
}

.notice-type.activity {
  background: linear-gradient(135deg, rgba(250, 173, 20, 0.1) 0%, rgba(250, 173, 20, 0.05) 100%);
  color: var(--warning-color);
}

.notice-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.notice-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.notice-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF4D4F 0%, #FF7875 100%);
  flex-shrink: 0;
  margin-left: 12rpx;
}

.notice-item.read .notice-title {
  color: var(--text-tertiary);
  font-weight: 400;
}

.notice-item.read .notice-content {
  color: var(--text-tertiary);
}

.notice-content {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ==================== 家校沟通 ==================== */
.chat-section {
  padding: 24rpx;
}

.chat-list {
  margin-bottom: 24rpx;
}

.chat-item {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  position: relative;
  transition: all 0.25s ease;
}

.chat-item:active {
  transform: scale(0.99);
}

.chat-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.2);
}

.chat-info {
  flex: 1;
  overflow: hidden;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.chat-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.chat-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.chat-class {
  font-size: 26rpx;
  color: var(--primary-color);
  margin-bottom: 6rpx;
  font-weight: 500;
}

.chat-last {
  font-size: 26rpx;
  color: var(--text-tertiary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.unread-badge {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  background: linear-gradient(135deg, #FF4D4F 0%, #FF7875 100%);
  color: #FFFFFF;
  font-size: 20rpx;
  border-radius: 16rpx;
  padding: 0 8rpx;
  text-align: center;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.1) 0%, rgba(54, 181, 160, 0.05) 100%);
  border-radius: 50%;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-placeholder);
}

/* ==================== 页面头部未读提示 ==================== */
.header-badge {
  font-size: 24rpx;
  color: var(--error-color);
  margin-left: 16rpx;
}

/* ==================== 长按提示 ==================== */
.long-press-tip {
  text-align: center;
  padding: 24rpx 0 48rpx;
}

.long-press-tip .tip-text {
  font-size: 24rpx;
  color: var(--text-placeholder);
}
