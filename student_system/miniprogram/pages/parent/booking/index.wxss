/* pages/parent/booking/index.wxss - 现代简约约课页面 */

.booking-container {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding-bottom: 200rpx;
}

/* ==================== 学员信息 ==================== */
.student-section {
  background: linear-gradient(165deg, #4A90D9 0%, #36B5A0 100%);
  padding: 32rpx;
  position: relative;
  overflow: hidden;
}

.student-section::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.student-card {
  background-color: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.student-row {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.student-row .label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  width: 80rpx;
  flex-shrink: 0;
}

.student-row .value {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.change-student {
  text-align: right;
  padding-top: 12rpx;
  margin-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.change-student text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* ==================== 学员选择器 ==================== */
.student-picker-section {
  margin: 24rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.student-picker-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.student-picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
}

.student-picker-item:active {
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.1) 0%, rgba(54, 181, 160, 0.05) 100%);
  border-color: var(--primary-color);
}

.picker-student-name {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.picker-student-class {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ==================== 通用区块 ==================== */
.section {
  margin: 24rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.date-hint {
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-weight: 400;
}

/* ==================== 日期选择器 ==================== */
.date-scroll {
  white-space: nowrap;
  margin: 0 -8rpx;
}

.date-list {
  display: inline-flex;
  gap: 12rpx;
  padding: 0 8rpx;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
}

.date-item.active {
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.1) 0%, rgba(54, 181, 160, 0.05) 100%);
  border-color: var(--primary-color);
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.15);
}

.date-item.past {
  opacity: 0.4;
}

.date-day {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.date-num {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.date-item.active .date-day,
.date-item.active .date-num {
  color: var(--primary-color);
}

/* ==================== 时间段网格 ==================== */
.time-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.time-slot {
  width: calc(50% - 8rpx);
  padding: 24rpx 16rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  text-align: center;
  box-sizing: border-box;
  transition: all 0.25s ease;
}

.time-slot.selected {
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.1) 0%, rgba(54, 181, 160, 0.05) 100%);
  border-color: var(--primary-color);
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.15);
}

.time-slot.disabled {
  background: linear-gradient(135deg, #F0F0F0 0%, #E8E8E8 100%);
  border-color: transparent;
  opacity: 0.6;
}

.slot-time {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
  margin-bottom: 4rpx;
}

.slot-status {
  display: block;
  font-size: 22rpx;
  color: var(--success-color);
  font-weight: 500;
}

.time-slot.disabled .slot-time {
  color: var(--text-tertiary);
}

.time-slot.disabled .slot-status {
  color: var(--text-tertiary);
}

.time-slot.selected .slot-time {
  color: var(--primary-color);
}

.time-slot.selected .slot-status {
  color: var(--primary-color);
}

/* ==================== 加载状态 ==================== */
.loading-state {
  text-align: center;
  padding: 40rpx 0;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

/* ==================== 确认预约 ==================== */
.confirm-section {
  position: fixed;
  bottom: 100rpx;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.confirm-info {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.btn-confirm {
  width: 200rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 29rpx;
  font-weight: 600;
  padding: 0;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
  border: none;
  transition: all 0.25s ease;
  letter-spacing: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-confirm:active {
  transform: scale(0.98);
}

.btn-confirm::after {
  border: none;
}

/* ==================== 底部入口 ==================== */
.footer-link {
  margin: 24rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.footer-link text {
  font-size: 28rpx;
  color: var(--primary-color);
  font-weight: 500;
}

.footer-link .arrow {
  color: var(--text-tertiary);
}

/* ==================== 空状态 ==================== */
.empty-state {
  text-align: center;
  padding: 48rpx 0;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

/* ==================== 老师选择器 ==================== */
.teacher-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
}

.teacher-picker:active {
  border-color: var(--primary-color);
}

.teacher-value {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.picker-arrow {
  font-size: 28rpx;
  color: var(--text-tertiary);
}
