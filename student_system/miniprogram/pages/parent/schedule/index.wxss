/* pages/parent/schedule/index.wxss - 现代简约课表页面 */

.schedule-container {
  min-height: 100vh;
  background-color: var(--bg-page);
}

/* ==================== 周选择器 ==================== */
.week-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
}

.week-nav {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  font-size: 28rpx;
  color: #FFFFFF;
  transition: all 0.2s ease;
}

.week-nav:active {
  background-color: rgba(255, 255, 255, 0.3);
  transform: scale(0.95);
}

.week-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}

/* ==================== 日期栏 ==================== */
.date-bar {
  display: flex;
  background-color: #FFFFFF;
  padding: 16rpx 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.date-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  margin: 0 4rpx;
  border-radius: 16rpx;
  transition: all 0.25s ease;
}

.date-item.today {
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.1) 0%, rgba(54, 181, 160, 0.05) 100%);
}

.day-name {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}

.day-date {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.date-item.today .day-name {
  color: var(--primary-color);
}

.date-item.today .day-date {
  color: var(--primary-color);
  font-weight: 700;
}

.date-item.selected {
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.3);
}

.date-item.selected .day-name {
  color: rgba(255, 255, 255, 0.9);
}

.date-item.selected .day-date {
  color: #FFFFFF;
  font-weight: 700;
}

/* ==================== 课程列表 ==================== */
.course-list {
  padding: 24rpx;
}

.course-list-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.course-item {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.25s ease;
}

.course-item:active {
  transform: scale(0.99);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.06);
}

.course-time {
  width: 100rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-right: 16rpx;
  border-right: 2rpx solid rgba(0, 0, 0, 0.06);
  margin-right: 16rpx;
}

.time-start {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.time-end {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

.course-info {
  flex: 1;
}

.course-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.course-detail {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 4rpx;
}

.course-students {
  font-size: 24rpx;
  color: var(--primary-color);
  display: block;
  margin-top: 8rpx;
  padding: 6rpx 12rpx;
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.1) 0%, rgba(54, 181, 160, 0.05) 100%);
  border-radius: 8rpx;
  display: inline-block;
}

/* ==================== 空状态 ==================== */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  color: var(--text-tertiary);
  font-size: 28rpx;
}
