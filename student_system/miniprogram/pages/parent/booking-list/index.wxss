/* pages/parent/booking-list/index.wxss - 现代简约约课列表页面 */

.booking-list-container {
  min-height: 100vh;
  background-color: var(--bg-page);
}

/* ==================== 统计栏 ==================== */
.stats-bar {
  padding: 24rpx 32rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
  background-color: #FFFFFF;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

/* ==================== 列表 ==================== */
.list {
  padding: 24rpx;
}

.booking-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.25s ease;
}

.booking-card:active {
  transform: scale(0.99);
}

.booking-main {
  margin-bottom: 8rpx;
}

.booking-date-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.booking-date {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: 16rpx;
}

.booking-slot {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.1) 0%, rgba(54, 181, 160, 0.05) 100%);
  border-radius: 8rpx;
}

.booking-info-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 12rpx;
}

.booking-teacher,
.booking-student {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.booking-status-row {
  margin-bottom: 4rpx;
}

.status-tag {
  display: inline-block;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.status-tag.booked {
  color: var(--primary-color);
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.1) 0%, rgba(54, 181, 160, 0.05) 100%);
}

.status-tag.cancelled {
  color: var(--text-tertiary);
  background-color: rgba(0, 0, 0, 0.04);
}

.status-tag.completed {
  color: var(--success-color);
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.1) 0%, rgba(82, 196, 26, 0.05) 100%);
}

.booking-actions {
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  margin-top: 8rpx;
}

.btn-cancel {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  border-radius: 16rpx;
  background-color: #FFFFFF;
  color: var(--error-color);
  border: 2rpx solid var(--error-color);
  transition: all 0.25s ease;
}

.btn-cancel:active {
  background: linear-gradient(135deg, rgba(255, 77, 79, 0.1) 0%, rgba(255, 77, 79, 0.05) 100%);
}

/* ==================== 空状态 ==================== */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  color: var(--text-tertiary);
  font-size: 28rpx;
}
