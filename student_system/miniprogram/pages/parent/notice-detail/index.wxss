/* pages/parent/notice-detail/index.wxss - 现代简约公告详情页面 */

.detail-container {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding: 24rpx;
}

.notice-detail {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.notice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.notice-type {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.notice-type.important {
  background: linear-gradient(135deg, rgba(255, 77, 79, 0.1) 0%, rgba(255, 77, 79, 0.05) 100%);
  color: var(--error-color);
}

.notice-type.activity {
  background: linear-gradient(135deg, rgba(250, 173, 20, 0.1) 0%, rgba(250, 173, 20, 0.05) 100%);
  color: var(--warning-color);
}

.notice-time {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.notice-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 28rpx;
  line-height: 1.4;
  letter-spacing: 1rpx;
}

.notice-content {
  font-size: 30rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  white-space: pre-wrap;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: var(--text-tertiary);
  font-size: 28rpx;
}
