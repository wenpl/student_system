/* pages/admin/schedule/index.wxss - 现代简约排课管理页面 */

.schedule-manage {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding-bottom: 120rpx;
}

/* ==================== 统计栏 ==================== */
.stats-bar {
  padding: 24rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ==================== 排课列表 ==================== */
.schedule-list {
  padding: 0 24rpx;
}

.schedule-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.25s ease;
}

.schedule-card:active {
  transform: scale(0.99);
}

.schedule-card.today {
  border-left: 6rpx solid var(--primary-color);
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.04) 0%, #FFFFFF 100%);
}

.schedule-card.past {
  opacity: 0.6;
}

.schedule-main {
  margin-bottom: 16rpx;
}

.schedule-date {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.date-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: 16rpx;
}

.day-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-right: 16rpx;
}

.today-badge {
  font-size: 22rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.schedule-info {
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  padding: 16rpx;
}

.course-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.detail-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 8rpx;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.time-text, .location-text, .class-text, .teacher-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* ==================== 操作按钮 ==================== */
.schedule-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.btn-edit, .btn-delete {
  flex: 1;
  height: 72rpx;
  font-size: 26rpx;
  border-radius: 16rpx;
  font-weight: 500;
  border: none;
  transition: all 0.25s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-edit {
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.2);
}

.btn-delete {
  background-color: #FFFFFF;
  color: var(--error-color);
  border: 2rpx solid var(--error-color);
}

/* ==================== 新增按钮 ==================== */
.add-btn {
  position: fixed;
  bottom: 48rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  padding: 24rpx 64rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.35);
  border: none;
}

/* ==================== 空状态 ==================== */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  color: var(--text-tertiary);
  font-size: 28rpx;
}
