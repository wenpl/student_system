<!--pages/admin/schedule/index.wxml-->
<view class="schedule-manage">
  <!-- 统计信息 -->
  <view class="stats-bar">
    <text>共 {{schedules.length}} 条排课记录</text>
  </view>

  <!-- 排课列表 -->
  <view wx:if="{{schedules.length === 0}}" class="empty-state">
    <text>暂无排课数据</text>
  </view>
  <view wx:else class="schedule-list">
    <view class="schedule-card {{item.isToday ? 'today' : ''}} {{item.isPast ? 'past' : ''}}" wx:for="{{schedules}}" wx:key="_id">
      <view class="schedule-main">
        <view class="schedule-date">
          <text class="date-text">{{item.dateText}}</text>
          <text class="day-text">{{item.dayText}}</text>
          <text wx:if="{{item.isToday}}" class="today-badge">今日</text>
        </view>
        <view class="schedule-info">
          <view class="course-name">{{item.courseName}}</view>
          <view class="detail-row">
            <text class="time-text">{{item.startTime}} - {{item.endTime}}</text>
            <text class="location-text">{{item.location}}</text>
          </view>
          <view class="detail-row">
            <text class="class-text">{{item.className}}</text>
            <text class="teacher-text">{{item.teacherName}}</text>
          </view>
        </view>
      </view>
      <view class="schedule-actions">
        <button class="btn-edit" catchtap="editSchedule" data-id="{{item._id}}">编辑</button>
        <button class="btn-delete" catchtap="deleteSchedule" data-id="{{item._id}}">删除</button>
      </view>
    </view>
  </view>

  <!-- 新增按钮 -->
  <view class="add-btn" bindtap="addSchedule">
    <text>+ 新增排课</text>
  </view>
</view>
