<!--pages/admin/student/index.wxml-->
<view class="student-manage">
  <!-- 搜索和筛选 -->
  <view class="search-section">
    <view class="search-bar">
      <input placeholder="搜索学员姓名" bindinput="onSearch" value="{{keyword}}" />
    </view>
    <view class="filter-btn {{filterClass ? 'active' : ''}}" bindtap="toggleFilter">
      <text>筛选</text>
    </view>
  </view>

  <!-- 筛选面板 -->
  <view wx:if="{{showFilter}}" class="filter-panel">
    <view class="filter-header">
      <text>按班级筛选</text>
      <text class="clear-btn" bindtap="clearFilter">清除</text>
    </view>
    <view class="filter-options">
      <view class="filter-option {{filterClass === '' ? 'active' : ''}}" bindtap="selectClass" data-id="">全部</view>
      <view class="filter-option {{filterClass === item._id ? 'active' : ''}}"
            wx:for="{{classList}}" wx:key="_id"
            bindtap="selectClass" data-id="{{item._id}}">
        {{item.name}}
      </view>
    </view>
  </view>

  <!-- 统计信息 -->
  <view class="stats-bar">
    <text>共 {{students.length}} 名学员</text>
  </view>

  <!-- 学员列表 -->
  <view wx:if="{{students.length === 0}}" class="empty-state">
    <text>暂无学员数据</text>
  </view>
  <view wx:else class="student-list">
    <view class="student-card" wx:for="{{students}}" wx:key="_id">
      <view class="student-main" bindtap="viewDetail" data-id="{{item._id}}">
        <view class="student-avatar">
          <text>{{item.nameCn[0]}}</text>
        </view>
        <view class="student-info">
          <view class="name-row">
            <text class="name-cn">{{item.nameCn}}</text>
            <text class="name-en">{{item.nameEn}}</text>
          </view>
          <view class="meta-row">
            <text class="class-name">{{item.className || '未分班'}}</text>
          </view>
        </view>
      </view>
      <view class="student-actions">
        <button class="btn-edit" catchtap="editStudent" data-id="{{item._id}}">编辑</button>
        <button class="btn-delete" catchtap="deleteStudent" data-id="{{item._id}}">删除</button>
      </view>
    </view>
  </view>

  <!-- 新增按钮 -->
  <view class="add-btn" bindtap="addStudent">
    <text>+ 新增学员</text>
  </view>
</view>
