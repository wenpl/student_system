/* pages/admin/teacher/edit/index.wxss - 现代简约老师编辑页面 */

.edit-container {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding: 24rpx;
  padding-bottom: 140rpx;
}

/* ==================== 表单区块 ==================== */
.form-section {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
  box-sizing: border-box;
}

.form-input:focus {
  background: #FFFFFF;
  border-color: var(--primary-color);
}

/* ==================== 密码操作 ==================== */
.btn-reset-pwd {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, rgba(255, 77, 79, 0.1) 0%, rgba(255, 77, 79, 0.05) 100%);
  color: var(--error-color);
  border-radius: 16rpx;
  font-size: 28rpx;
  border: none;
  font-weight: 500;
  transition: all 0.25s ease;
}

.btn-reset-pwd:active {
  transform: scale(0.98);
}

.btn-reset-pwd::after {
  border: none;
}

.password-actions {
  display: flex;
  gap: 16rpx;
  width: 100%;
}

.btn-set-pwd {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.1) 0%, rgba(54, 181, 160, 0.05) 100%);
  color: var(--primary-color);
  border-radius: 16rpx;
  font-size: 28rpx;
  border: none;
  font-weight: 500;
  transition: all 0.25s ease;
}

.btn-set-pwd:active {
  transform: scale(0.98);
}

.btn-set-pwd::after {
  border: none;
}

.password-form {
  padding: 0 0 24rpx 0;
}

.btn-confirm-pwd {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: none;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.2);
}

.btn-confirm-pwd::after {
  border: none;
}

/* ==================== 保存按钮 ==================== */
.btn-save {
  position: fixed;
  bottom: 48rpx;
  left: 24rpx;
  right: 24rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 35rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 217, 0.3);
  letter-spacing: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
