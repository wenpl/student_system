/* pages/admin/teacher/index.wxss - 现代简约老师管理页面 */

.teacher-manage {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding-bottom: 120rpx;
}

/* ==================== 统计栏 ==================== */
.stats-bar {
  padding: 24rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ==================== 老师列表 ==================== */
.teacher-list {
  padding: 0 24rpx;
}

.teacher-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.25s ease;
}

.teacher-card:active {
  transform: scale(0.99);
}

.teacher-main {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.teacher-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #52C41A 0%, #73D13D 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 700;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(82, 196, 26, 0.3);
}

.teacher-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.teacher-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.status-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.status-badge.active {
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.1) 0%, rgba(82, 196, 26, 0.05) 100%);
  color: var(--success-color);
}

.meta-row {
  margin-bottom: 4rpx;
}

.phone-text, .class-count {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* ==================== 操作按钮 ==================== */
.teacher-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.btn-edit, .btn-delete {
  flex: 1;
  height: 72rpx;
  font-size: 26rpx;
  border-radius: 16rpx;
  font-weight: 500;
  border: none;
  transition: all 0.25s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-edit {
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.2);
}

.btn-delete {
  background-color: #FFFFFF;
  color: var(--error-color);
  border: 2rpx solid var(--error-color);
}

/* ==================== 新增按钮 ==================== */
.add-btn {
  position: fixed;
  bottom: 48rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  padding: 24rpx 64rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.35);
  border: none;
}

/* ==================== 空状态 ==================== */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  color: var(--text-tertiary);
  font-size: 28rpx;
}
