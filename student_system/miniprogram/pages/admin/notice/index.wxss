/* pages/admin/notice/index.wxss - 现代简约公告管理页面 */

.notice-container {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding-bottom: 120rpx;
}

/* ==================== 标签栏 ==================== */
.tab-bar {
  display: flex;
  background-color: #FFFFFF;
  padding: 16rpx 24rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: var(--text-secondary);
  position: relative;
  transition: all 0.25s ease;
}

.tab-item.active {
  color: var(--primary-color);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #4A90D9 0%, #36B5A0 100%);
  border-radius: 3rpx;
}

/* ==================== 公告列表 ==================== */
.notice-list {
  padding: 24rpx;
}

.notice-item {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.25s ease;
}

.notice-item:active {
  transform: scale(0.99);
}

.notice-content {
  padding: 28rpx;
}

.notice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.notice-type {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.notice-type.important {
  background: linear-gradient(135deg, rgba(255, 77, 79, 0.1) 0%, rgba(255, 77, 79, 0.05) 100%);
  color: var(--error-color);
}

.notice-type.activity {
  background: linear-gradient(135deg, rgba(250, 173, 20, 0.1) 0%, rgba(250, 173, 20, 0.05) 100%);
  color: var(--warning-color);
}

.notice-time {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.notice-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.notice-preview {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.6;
}

.notice-actions {
  display: flex;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-right: 1rpx solid rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.action-btn:last-child {
  border-right: none;
}

.action-btn:active {
  background-color: rgba(0, 0, 0, 0.02);
}

.action-btn.publish {
  color: var(--success-color);
}

.action-btn.edit {
  color: var(--primary-color);
}

.action-btn.delete {
  color: var(--error-color);
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.1) 0%, rgba(54, 181, 160, 0.05) 100%);
  border-radius: 50%;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-tertiary);
}

/* ==================== 添加按钮 ==================== */
.add-btn {
  position: fixed;
  bottom: 48rpx;
  right: 48rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.4);
  border: none;
  transition: all 0.25s ease;
}

.add-btn:active {
  transform: scale(0.95);
}

.add-btn text {
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: 300;
}
