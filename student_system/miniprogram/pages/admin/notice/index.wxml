<!--pages/admin/notice/index.wxml-->
<view class="notice-container">
  <!-- 标签切换 -->
  <view class="tab-bar">
    <view class="tab-item {{currentTab === 'published' ? 'active' : ''}}" bindtap="switchTab" data-tab="published">已发布</view>
    <view class="tab-item {{currentTab === 'draft' ? 'active' : ''}}" bindtap="switchTab" data-tab="draft">草稿箱</view>
  </view>

  <!-- 公告列表 -->
  <view wx:if="{{filteredNotices.length === 0}}" class="empty-state">
    <view class="empty-icon"></view>
    <text class="empty-text">暂无公告</text>
  </view>

  <view wx:else class="notice-list">
    <view class="notice-item" wx:for="{{filteredNotices}}" wx:key="_id">
      <view class="notice-content" bindtap="editNotice" data-id="{{item._id}}">
        <view class="notice-header">
          <view class="notice-type {{item.type === 'important' ? 'important' : item.type === 'activity' ? 'activity' : ''}}">{{item.typeText}}</view>
          <text class="notice-time">{{item.timeText}}</text>
        </view>
        <view class="notice-title">{{item.title}}</view>
        <view class="notice-preview">{{item.content}}</view>
      </view>
      <view class="notice-actions">
        <view wx:if="{{item.status === 'draft'}}" class="action-btn publish" catchtap="publishNotice" data-id="{{item._id}}">发布</view>
        <view class="action-btn edit" catchtap="editNotice" data-id="{{item._id}}">编辑</view>
        <view class="action-btn delete" catchtap="deleteNotice" data-id="{{item._id}}">删除</view>
      </view>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="add-btn" bindtap="goToAdd">
    <text>+</text>
  </view>
</view>
