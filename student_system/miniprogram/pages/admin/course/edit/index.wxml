<!--pages/admin/course/edit/index.wxml-->
<view class="edit-container">
  <view class="form-section">
    <view class="form-item">
      <text class="form-label">课程名称 *</text>
      <input class="form-input" placeholder="请输入课程名称" bindinput="onNameInput" value="{{name}}" />
    </view>

    <view class="form-item">
      <text class="form-label">课程价格</text>
      <input class="form-input" type="digit" placeholder="请输入价格" bindinput="onPriceInput" value="{{price}}" />
    </view>

    <view class="form-item">
      <text class="form-label">课时数</text>
      <input class="form-input" type="number" placeholder="请输入课时数" bindinput="onHoursInput" value="{{hours}}" />
    </view>

    <view class="form-item">
      <text class="form-label">课程说明</text>
      <textarea class="form-textarea" placeholder="请输入课程说明" bindinput="onDescInput" value="{{description}}" maxlength="200"></textarea>
    </view>
  </view>

  <button class="btn-save" bindtap="save">保存</button>
</view>
