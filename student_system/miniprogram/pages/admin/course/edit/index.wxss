/* pages/admin/course/edit/index.wxss - 现代简约课程编辑页面 */

.edit-container {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding: 24rpx;
  padding-bottom: 140rpx;
}

/* ==================== 表单区块 ==================== */
.form-section {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
  box-sizing: border-box;
}

.form-input:focus {
  background: #FFFFFF;
  border-color: var(--primary-color);
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
}

.form-textarea:focus {
  background: #FFFFFF;
  border-color: var(--primary-color);
}

/* ==================== 保存按钮 ==================== */
.btn-save {
  position: fixed;
  bottom: 48rpx;
  left: 24rpx;
  right: 24rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 35rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 217, 0.3);
  letter-spacing: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
