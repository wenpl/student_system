<!--pages/admin/course/index.wxml-->
<view class="course-manage">
  <!-- 统计信息 -->
  <view class="stats-bar">
    <text>共 {{courses.length}} 门课程</text>
  </view>

  <!-- 课程列表 -->
  <view wx:if="{{courses.length === 0}}" class="empty-state">
    <text>暂无课程数据</text>
  </view>
  <view wx:else class="course-list">
    <view class="course-card" wx:for="{{courses}}" wx:key="_id">
      <view class="course-main">
        <view class="course-header">
          <text class="course-name">{{item.name}}</text>
          <text class="course-price">¥{{item.price}}</text>
        </view>
        <view class="course-body">
          <view class="info-item">
            <text class="info-label">课时数：</text>
            <text class="info-value">{{item.hours}} 课时</text>
          </view>
          <view class="info-item">
            <text class="info-label">课程说明：</text>
            <text class="info-value">{{item.description || '暂无'}}</text>
          </view>
        </view>
      </view>
      <view class="course-actions">
        <button class="btn-edit" catchtap="editCourse" data-id="{{item._id}}">编辑</button>
        <button class="btn-delete" catchtap="deleteCourse" data-id="{{item._id}}">删除</button>
      </view>
    </view>
  </view>

  <!-- 新增按钮 -->
  <view class="add-btn" bindtap="addCourse">
    <text>+ 新增课程</text>
  </view>
</view>
