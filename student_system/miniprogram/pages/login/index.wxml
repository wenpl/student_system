<!--pages/login/index.wxml-->
<view class="login-container">
  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo-icon">
      <view class="logo-icon-inner">
        <text class="logo-emoji">🌱</text>
        <text class="logo-letters">ABC</text>
      </view>
    </view>
    <text class="app-name">英语启蒙培训班</text>
    <text class="app-slogan">让学习更轻松，让成长更快乐</text>
  </view>

  <!-- 手机号登录 -->
  <view class="login-section" wx:if="{{pageMode === 'login'}}">
    <!-- 角色选择 -->
    <view class="phone-role-select">
      <view class="phone-role-item {{phoneRole === 'parent' ? 'active' : ''}}" bindtap="selectPhoneRole" data-role="parent">家长</view>
      <view class="phone-role-item {{phoneRole === 'teacher' ? 'active' : ''}}" bindtap="selectPhoneRole" data-role="teacher">老师</view>
      <view class="phone-role-item {{phoneRole === 'admin' ? 'active' : ''}}" bindtap="selectPhoneRole" data-role="admin">管理员</view>
    </view>

    <view class="phone-login-form">
      <input class="login-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{phoneNumber}}" bindinput="onPhoneNumberInput" />
      <input class="login-input" type="text" password="{{true}}" placeholder="请输入密码" value="{{phonePassword}}" bindinput="onPhonePasswordInput" />
      <button class="btn-phone-login" bindtap="handlePhoneLogin">登 录</button>
    </view>

    <view class="switch-link" bindtap="switchPageMode" data-mode="register">
      <text>没有账号？立即注册</text>
    </view>
  </view>

  <!-- 家长注册 -->
  <view class="login-section" wx:if="{{pageMode === 'register'}}">
    <view class="register-title">家长注册</view>
    <view class="phone-login-form">
      <input class="login-input" type="text" placeholder="请输入姓名" value="{{regName}}" bindinput="onRegNameInput" />
      <input class="login-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{regPhone}}" bindinput="onRegPhoneInput" />
      <input class="login-input" type="text" password="{{true}}" placeholder="请输入密码(6-20位)" maxlength="20" value="{{regPassword}}" bindinput="onRegPasswordInput" />
      <input class="login-input" type="text" password="{{true}}" placeholder="请确认密码" maxlength="20" value="{{regConfirmPassword}}" bindinput="onRegConfirmPasswordInput" />
      <button class="btn-phone-login" bindtap="handleRegister">注 册</button>
    </view>

    <view class="switch-link" bindtap="switchPageMode" data-mode="login">
      <text>已有账号？返回登录</text>
    </view>
  </view>

  <view class="login-tips">
    <text>登录即表示同意</text>
    <text class="link">《用户协议》</text>
    <text>和</text>
    <text class="link">《隐私政策》</text>
  </view>
</view>
