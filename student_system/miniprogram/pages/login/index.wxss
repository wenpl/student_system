/* pages/login/index.wxss - 现代简约登录页面 */

.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(165deg, #4A90D9 0%, #36B5A0 50%, #2A9D8A 100%);
  position: relative;
  overflow: hidden;
}

/* 装饰背景 */
.login-container::before {
  content: '';
  position: absolute;
  top: -200rpx;
  right: -200rpx;
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.login-container::after {
  content: '';
  position: absolute;
  bottom: -300rpx;
  left: -200rpx;
  width: 800rpx;
  height: 800rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
  border-radius: 50%;
}

/* Logo区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0 60rpx;
  position: relative;
  z-index: 1;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #F0F8FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.15);
  border: 3rpx solid rgba(255, 255, 255, 0.8);
}

.logo-icon-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.logo-emoji {
  font-size: 48rpx;
  margin-bottom: 4rpx;
}

.logo-letters {
  font-size: 32rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: 2rpx;
}

.app-name {
  font-size: 52rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.app-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
}

/* 登录区域 */
.login-section {
  flex: 1;
  padding: 0 48rpx 40rpx;
  position: relative;
  z-index: 1;
}

/* 角色选择 */
.phone-role-select {
  display: flex;
  justify-content: center;
  margin-bottom: 48rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 48rpx;
  padding: 6rpx;
  backdrop-filter: blur(10px);
}

.phone-role-item {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 44rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  transition: all 0.3s ease;
}

.phone-role-item.active {
  background-color: #FFFFFF;
  color: var(--primary-color);
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

/* 表单 */
.phone-login-form {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.12);
  backdrop-filter: blur(10px);
}

.login-input {
  width: 100%;
  height: 96rpx;
  background-color: #F5F7FA;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
  color: var(--text-primary);
}

.login-input:focus {
  background-color: #FFFFFF;
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(74, 144, 217, 0.15);
}

.login-input::placeholder {
  color: var(--text-tertiary);
}

.login-input:last-of-type {
  margin-bottom: 0;
}

.btn-phone-login {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #36B5A0 100%);
  color: #FFFFFF;
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: 700;
  border: none;
  margin-top: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.35);
  transition: all 0.3s ease;
  letter-spacing: 8rpx;
  text-align: center;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-phone-login:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

.btn-phone-login::after {
  border: none;
}

/* 切换链接 */
.switch-link {
  text-align: center;
  padding: 32rpx 0 16rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 注册标题 */
.register-title {
  text-align: center;
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 600;
  margin-bottom: 40rpx;
  letter-spacing: 2rpx;
}

/* 底部提示 */
.login-tips {
  text-align: center;
  padding: 40rpx 48rpx 80rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  position: relative;
  z-index: 1;
}

.link {
  color: #FFFFFF;
  text-decoration: underline;
  text-underline-offset: 4rpx;
}
